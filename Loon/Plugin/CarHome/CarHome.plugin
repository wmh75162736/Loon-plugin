#!name=汽车之家去广告
#!desc=移除开屏弹窗、信息流广告、选车与品牌页推广、社区横幅及二手车插卡；保留正常内容与车辆列表。
#!author=ChatGPT
#!homepage=https://github.com/wmh75162736/Loon-plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/AutoHome.png
#!date=2026-06-20

[Script]
# 仅清理抓包确认的运营广告字段；不改写 mycard、账号、车辆和正常资讯接口。
http-response ^https?:\/\/mobile\.app\.autohome\.com\.cn\/platform\/app-ops-product-api\/(?:pageCard\/queryPageCardData|resource\/queryresourcedatas)(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家运营广告净化, enable=true
http-response ^https?:\/\/club\.app\.autohome\.com\.cn\/club_v\d+(?:\.\d+){2}\/club\/index\/businessv\d+(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家社区运营横幅, enable=true
http-response ^https?:\/\/cars\.app\.autohome\.com\.cn\/carstreaming\/clue\/getruleconfig(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家报价弹窗, enable=true
http-response ^https?:\/\/(?:a\.athm\.cn\/)?cars\.app\.autohome\.com\.cn\/carstreaming\/selectcarportal\/reclist(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家移除直播浮窗, enable=true
http-response ^https?:\/\/(?:a\.athm\.cn\/)?cars\.app\.autohome\.com\.cn\/carstreaming\/selectcarportal\/seriestopwithtagscard(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家移除报价页直播, enable=true
http-response ^https?:\/\/news\.app\.autohome\.com\.cn\/car_v\d+(?:\.\d+){2}\/indexpage\/reclist(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家选车页推广, enable=true
http-response ^https?:\/\/news\.app\.autohome\.com\.cn\/car_v\d+(?:\.\d+){2}\/brandseriespage\/seriestopwithtags(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家品牌页推广, enable=true
http-response ^https?:\/\/news\.app\.autohome\.com\.cn\/shouye_v\d+(?:\.\d+){2}\/news\/feed(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家信息流广告, enable=true
http-response ^https?:\/\/apiautoappusc\.che168\.com\/apic\/v\d+\/gethomepagefeed(?:\?.*)?$ script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/main/Loon/Plugin/CarHome/CarHome.js, requires-body=true, timeout=10, tag=汽车之家二手车插卡, enable=true

[Map Local]
# 抓包确认的广告创意、运营导航和广告服务接口；不匹配“我的”核心接口 mycardv8。
^https?:\/\/pcmx\.autohome\.com\.cn\/queryCreativeList(?:\?.*)?$ data-type=text data="{\"returncode\":0,\"message\":\"\",\"result\":{}}" status-code=200 header="Content-Type: application/json"
^https?:\/\/news\.app\.autohome\.com\.cn\/news_v\d+(?:\.\d+){2}\/news\/operatenavigation(?:\?.*)?$ data-type=text data="{\"returncode\":0,\"message\":\"\",\"result\":{}}" status-code=200 header="Content-Type: application/json"
^https?:\/\/adproxy\.autohome\.com\.cn\/AdvertiseService\/AppHandler\.ashx(?:\?.*)?$ data-type=text data="{\"returncode\":0,\"message\":\"\",\"result\":{}}" status-code=200 header="Content-Type: application/json"
^https?:\/\/maam\.pingan\.com\.cn\/maam\/buoy\/getBuoyList\.do(?:\?.*)?$ data-type=text data="{\"returncode\":0,\"message\":\"\",\"result\":{}}" status-code=200 header="Content-Type: application/json"

[Rule]
# 本次抓包中该域名仅返回 admdfs 广告素材。
DOMAIN,adm2.autoimg.cn,REJECT

[MITM]
hostname = mobile.app.autohome.com.cn, pcmx.autohome.com.cn, news.app.autohome.com.cn, club.app.autohome.com.cn, cars.app.autohome.com.cn, a.athm.cn, apiautoappusc.che168.com, adproxy.autohome.com.cn, maam.pingan.com.cn
