#!name=音乐去广告
#!desc=QQ音乐、波点音乐开屏及互动广告精准拦截（安全版）
#!author=ChatGPT
#!version=1.4
#!date=2026-06-21
#!loon_version=3.4.0(962)

[URL Rewrite]
# QQ音乐：抓包确认的互动广告接口会在 c、c6、szc、shc、shc6 等主机间分流。
^https?:\/\/(?:c|c\d+|szc|shc|shc\d+)\.y\.qq\.com\/tips\/fcgi-bin\/fcg_get_advert\.fcg - reject-200

# 波点音乐：仅拦截启动开屏配置与兜底请求，不修改登录、首页、会员和播放配置。
^https?:\/\/bd-(?:api|lv)\.kuwo\.cn\/api\/popup\/start\/(?:info|fallback) - reject-200

[Rule]
# QQ音乐：原有广告分发、点击及统计规则
DOMAIN,adstats.tencentmusic.com,REJECT
DOMAIN,ad.tencentmusic.com,REJECT
DOMAIN,adcdn.tencentmusic.com,REJECT
DOMAIN,adcdn6.tencentmusic.com,REJECT
DOMAIN,adexpo.tencentmusic.com,REJECT
DOMAIN,adclick.tencentmusic.com,REJECT
DOMAIN,mc.tencentmusic.com,REJECT
DOMAIN,monitor.music.qq.com,REJECT
DOMAIN,tmead.y.qq.com,REJECT
DOMAIN,tmeadbak.y.qq.com,REJECT
DOMAIN,tmeadquic.y.qq.com,REJECT

[MITM]
hostname = c.y.qq.com, c6.y.qq.com, szc.y.qq.com, shc.y.qq.com, shc6.y.qq.com, bd-api.kuwo.cn, bd-lv.kuwo.cn
