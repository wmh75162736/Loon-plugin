#!name=音乐去广告
#!desc=QQ音乐互动广告、波点音乐开屏广告精准拦截
#!author=ChatGPT
#!version=1.5.1
#!date=2026-06-23
#!loon_version=3.4.0(962)

[URL Rewrite]
# QQ音乐：抓包确认的互动广告接口会在 c、c6、szc、szc6、shc、shc6 等主机间分流。
^https?:\/\/(?:c|c\d+|szc|szc\d+|shc|shc\d+)\.y\.qq\.com\/tips\/fcgi-bin\/fcg_get_advert\.fcg - reject-200

[Script]
# 波点音乐：只关闭开屏相关字段，保留账号、首页、播放和会员数据。
波点音乐开屏配置 = type=http-response,pattern=^https?:\/\/bd-(?:api|lv)\.kuwo\.cn\/api\/(?:popup\/start\/(?:info|fallback)|service\/advert\/config|advert\/free\/config),requires-body=1,script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/MusicAd/music-adblock.js

[Rule]
# QQ音乐：原有广告分发、点击及统计规则
DOMAIN,adstats.tencentmusic.com,REJECT
DOMAIN,ad.tencentmusic.com,REJECT
DOMAIN,adcdn.tencentmusic.com,REJECT
DOMAIN,adcdn6.tencentmusic.com,REJECT
DOMAIN,adexpo.tencentmusic.com,REJECT
DOMAIN,adclick.tencentmusic.com,REJECT
DOMAIN,mc.tencentmusic.com,REJECT
DOMAIN,monitor.music.qq.com,REJECT
DOMAIN,tmead.y.qq.com,REJECT
DOMAIN,tmeadbak.y.qq.com,REJECT
DOMAIN,tmeadquic.y.qq.com,REJECT

[MITM]
hostname = c.y.qq.com, c6.y.qq.com, szc.y.qq.com, szc6.y.qq.com, shc.y.qq.com, shc6.y.qq.com, bd-api.kuwo.cn, bd-lv.kuwo.cn
