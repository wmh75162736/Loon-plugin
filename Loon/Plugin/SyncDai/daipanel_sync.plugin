#!name=呆呆面板模块化自适应同步插件 (稳定版)
#!desc=解耦重构版：包含腾讯视频、小米商城、WPS。使用底层合并机制，100%成功抓取。
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Auto_Sync.png
#!date=2026-07-14

[MITM]
hostname = pbaccess.video.qq.com, shop-api.retail.mi.com, personal-act.wps.cn

[Script]
# --- 业务拦截层 (自动合并引入同步库) ---

# 腾讯视频抓取
http-request ^https:\/\/pbaccess\.video\.qq\.com script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_capture_vqq.js, requires-body=false, requires-by-js=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_sync_core.js, tag=腾讯视频抓取

# 小米抽奖抓取
http-request ^https:\/\/shop-api\.retail\.mi\.com\/mtop\/navi\/venue\/batch script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_capture_mi.js, requires-body=true, requires-by-js=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_sync_core.js, tag=小米抓取

# WPS抓取
http-request ^https:\/\/personal-act\.wps\.cn\/activity-rubik\/activity\/page_info script-path=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_capture_wps.js, requires-body=false, requires-by-js=https://raw.githubusercontent.com/wmh75162736/Loon-plugin/refs/heads/main/Loon/Plugin/SyncDai/daipanel_sync_core.js, tag=WPS抓取